# Frontend (Vite). Copy to `.env.local` only if you need overrides.

# Dev: Vite reads PORT from backend/.env and proxies /api → http://localhost:<PORT>.
# Do not set VITE_API_URL to the wrong port — it does NOT control the proxy (only production fetch base).

# To force the dev proxy to a specific API origin (e.g. custom host/port):
# BACKEND_URL=http://localhost:3002
